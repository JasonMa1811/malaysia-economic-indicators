# This is the committed template — copy it to .env before running:
#   cp .env.example .env
# .env itself is gitignored since it's your actual local config, even
# though these particular values are just harmless local-dev defaults.
# Defaults for local/demo use. Fine to commit — not production credentials.
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Data warehouse Postgres (separate from Airflow's own metadata DB).
# Power BI connects here: localhost, port 5433.
POSTGRES_DATA_USER=malaysia
POSTGRES_DATA_PASSWORD=malaysia
POSTGRES_DATA_DB=malaysia_indicators

# pgAdmin (web UI at http://localhost:5050) — login is this email/password,
# NOT the Postgres credentials above (those get typed once when you connect
# to the pre-loaded "Malaysia Indicators (Docker)" server inside pgAdmin).
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# If you hit file-permission issues on WSL2 (container-written files in
# data/ owned by a uid you can't edit from Windows/WSL), run this once
# from the project root and re-run docker compose up:
#   echo "AIRFLOW_UID=$(id -u)" > .env.local
# then add `env_file: [.env, .env.local]` — or just overwrite AIRFLOW_UID
# above with your `id -u` output.
