__pycache__/
*.pyc

# Airflow/Docker runtime artifacts — generated locally, not part of the repo
logs/
.env.local

# Your actual local config — .env.example is the committed template
.env

# Generated pipeline output — regenerates every run, would just be
# noisy diffs. Folder structure kept via .gitkeep.
data/raw/*.csv
data/processed/*.csv

# Airflow standalone (non-Docker) leaves these behind
airflow.cfg
airflow.db
airflow-webserver.pid

# dbt build artifacts — regenerate every run, shouldn't be committed
dbt/target/
dbt/logs/
dbt/.user.yml
